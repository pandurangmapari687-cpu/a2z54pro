<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>EduPortfolio | Clean About Section</title>
  <!-- Google Fonts & Font Awesome -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #f9fafc;
      color: #1e293b;
      scroll-behavior: smooth;
      line-height: 1.5;
      overflow-x: hidden;
    }

    ::-webkit-scrollbar {
      width: 8px;
    }
    ::-webkit-scrollbar-track {
      background: #e2e8f0;
    }
    ::-webkit-scrollbar-thumb {
      background: #5b21b6;
      border-radius: 12px;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 28px;
    }

    /* Navigation */
    nav {
      position: sticky;
      top: 0;
      background: rgba(255,255,255,0.94);
      backdrop-filter: blur(14px);
      z-index: 100;
      box-shadow: 0 4px 20px rgba(0,0,0,0.02);
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    .nav-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 0;
      flex-wrap: wrap;
    }
    .logo {
      font-weight: 800;
      font-size: 1.7rem;
      background: linear-gradient(135deg, #4f46e5, #8b5cf6);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: -0.5px;
      cursor: pointer;
      transition: transform 0.2s ease;
    }
    .logo:hover {
      transform: scale(1.02);
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .nav-links a {
      text-decoration: none;
      font-weight: 500;
      color: #334155;
      transition: 0.2s;
      font-size: 1rem;
    }
    .nav-links a:hover {
      color: #4f46e5;
    }
    .mobile-menu {
      display: none;
      font-size: 1.6rem;
      cursor: pointer;
      color: #1e293b;
    }

    /* Hero Section */
    .hero {
      padding: 70px 0 60px;
    }
    .hero-grid {
      display: flex;
      align-items: center;
      gap: 50px;
      flex-wrap: wrap;
      justify-content: space-between;
    }
    .hero-content {
      flex: 1;
    }
    .hero-badge {
      background: #e0e7ff;
      color: #4f46e5;
      padding: 6px 14px;
      border-radius: 40px;
      font-size: 0.85rem;
      font-weight: 600;
      display: inline-block;
      margin-bottom: 20px;
    }
    .hero-content h1 {
      font-size: 3.2rem;
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 20px;
    }
    .gradient-text {
      background: linear-gradient(to right, #0f172a, #4f46e5);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .hero-content p {
      font-size: 1.2rem;
      color: #475569;
      max-width: 550px;
      margin-bottom: 32px;
    }
    .btn-group {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }
    .btn-primary {
      background: #4f46e5;
      color: white;
      border: none;
      padding: 12px 28px;
      border-radius: 40px;
      font-weight: 600;
      cursor: pointer;
      transition: 0.25s;
      box-shadow: 0 8px 16px -8px rgba(79,70,229,0.3);
    }
    .btn-primary:hover {
      background: #6366f1;
      transform: translateY(-3px);
    }
    .btn-outline {
      background: transparent;
      border: 1.5px solid #cbd5e1;
      padding: 12px 28px;
      border-radius: 40px;
      font-weight: 600;
      cursor: pointer;
      transition: 0.25s;
    }
    .btn-outline:hover {
      border-color: #4f46e5;
      color: #4f46e5;
    }
    .profile-img {
      flex: 0.7;
      display: flex;
      justify-content: center;
    }
    .img-wrapper {
      width: 280px;
      height: 280px;
      background: linear-gradient(145deg, #eef2ff, #ffffff);
      border-radius: 58% 42% 65% 35% / 42% 40% 60% 58%;
      padding: 8px;
      box-shadow: 0 25px 40px -12px rgba(0,0,0,0.2);
      transition: transform 0.4s ease;
    }
    .img-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 52% 48% 62% 38% / 44% 44% 56% 56%;
      background: #f1f5f9;
    }
    .img-wrapper:hover {
      transform: scale(1.02) rotate(1deg);
    }

    /* ===== NEW SIMPLE ABOUT SECTION (दुसरा डिझाइन) ===== */
    .about-simple {
      background: transparent;
      padding: 60px 0;
    }
    .about-card {
      background: white;
      border-radius: 32px;
      padding: 40px;
      box-shadow: 0 12px 30px -12px rgba(0,0,0,0.08);
      border: 1px solid #eef2ff;
    }
    .about-flex {
      display: flex;
      gap: 48px;
      flex-wrap: wrap;
    }
    .about-left {
      flex: 2;
    }
    .about-left h3 {
      font-size: 1.8rem;
      margin-bottom: 16px;
      color: #0f172a;
    }
    .about-left p {
      color: #475569;
      margin-bottom: 20px;
      line-height: 1.7;
    }
    .quote {
      background: #f1f4ff;
      padding: 20px 24px;
      border-radius: 24px;
      margin: 24px 0;
      border-left: 4px solid #4f46e5;
      font-style: italic;
      color: #1e293b;
    }
    .quote i {
      color: #4f46e5;
      margin-right: 8px;
    }
    .about-right {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .stat-simple {
      background: #f8fafc;
      border-radius: 24px;
      padding: 20px;
      text-align: center;
      border: 1px solid #e2e8f0;
      transition: all 0.2s;
    }
    .stat-simple:hover {
      transform: translateY(-4px);
      border-color: #c7d2fe;
    }
    .stat-num {
      font-size: 2rem;
      font-weight: 800;
      color: #4f46e5;
    }
    .stat-label {
      color: #475569;
      font-size: 0.9rem;
      margin-top: 6px;
    }

    /* section common + slide-up animation */
    section {
      padding: 80px 0;
    }
    .slide-up {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .slide-up.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .section-title {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 48px;
      position: relative;
      display: inline-block;
    }
    .section-title:after {
      content: '';
      position: absolute;
      bottom: -12px;
      left: 0;
      width: 60%;
      height: 4px;
      background: linear-gradient(90deg, #4f46e5, #a78bfa);
      border-radius: 4px;
    }
    /* education cards */
    .edu-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 30px;
    }
    .edu-card {
      background: white;
      border-radius: 28px;
      padding: 28px;
      box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
      transition: all 0.3s ease;
      border: 1px solid #eef2ff;
    }
    .edu-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 30px -12px rgba(79,70,229,0.15);
    }
    .edu-icon {
      font-size: 2.2rem;
      color: #4f46e5;
      margin-bottom: 20px;
    }
    .edu-card h3 {
      font-size: 1.5rem;
      margin-bottom: 10px;
    }
    .edu-date {
      color: #6c63ff;
      font-weight: 500;
      margin-bottom: 12px;
      display: block;
    }



    #stats {
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  color: white;
  padding: 80px 0;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 30px;
  text-align: center;
}

.stat-box {
  background: rgba(255,255,255,0.1);
  padding: 30px;
  border-radius: 20px;
  backdrop-filter: blur(10px);
  transition: 0.3s;
}

.stat-box:hover {
  transform: translateY(-10px);
  background: rgba(255,255,255,0.2);
}

.stat-box h3 {
  font-size: 2.5rem;
  font-weight: 800;
}

.stat-box p {
  margin-top: 10px;
  font-size: 1rem;
}
    /* skills */
    #skills {
  padding: 70px 0;
  background: #fbf8fc;
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
  gap: 20px;
}

.skill-card {
  background: #ffffff;
  border-radius: 15px;
  padding: 20px;
  text-align: center;
  transition: 0.3s;
  box-shadow: 0 5px 15px rgba(0,0,0,0.08);
}

.skill-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.15);
}

/* ICON */
.skill-icon {
  font-size: 30px;
  margin-bottom: 10px;
  color: #3b82f6;
}

/* TEXT */
.skill-card span {
  font-size: 14px;
  font-weight: 600;
  color: #333;
}
    /* projects */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 32px;
    }
    .project-card {
      background: white;
      border-radius: 32px;
      overflow: hidden;
      transition: all 0.3s ease;
      box-shadow: 0 12px 20px -12px rgba(0,0,0,0.08);
      border: 1px solid #edf2f7;
    }
    .project-card:hover {
      transform: translateY(-8px) scale(1.01);
      border-color: #c7d2fe;
    }
    .project-content {
      padding: 24px;
    }
    .project-tag {
      background: #eef2ff;
      color: #4f46e5;
      border-radius: 30px;
      padding: 4px 14px;
      font-size: 0.75rem;
      font-weight: 600;
      display: inline-block;
      margin-bottom: 14px;
    }
    .project-card h3 {
      font-size: 1.4rem;
      margin-bottom: 12px;
    }
    .project-card p {
      color: #475569;
      margin-bottom: 20px;
    }
    .project-link {
      color: #4f46e5;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
    }
    /* contact */
    .contact-wrapper {
      display: flex;
      flex-wrap: wrap;
      gap: 40px;
      background: white;
      border-radius: 48px;
      padding: 48px;
      box-shadow: 0 20px 35px -12px rgba(0,0,0,0.05);
    }
    .contact-info {
      flex: 1;
    }
    .contact-info h3 {
      font-size: 1.7rem;
      margin-bottom: 20px;
    }
    .contact-detail {
      display: flex;
      align-items: center;
      gap: 18px;
      margin-bottom: 28px;
    }
    .contact-detail i {
      font-size: 1.6rem;
      color: #4f46e5;
      width: 40px;
    }
    .social-links {
      display: flex;
      gap: 20px;
      margin-top: 32px;
    }
    .social-links a {
      background: #f1f5f9;
      width: 48px;
      height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 60px;
      color: #1e293b;
      font-size: 1.4rem;
      transition: 0.2s;
    }
    .social-links a:hover {
      background: #4f46e5;
      color: white;
      transform: translateY(-4px);
    }
    .contact-form {
      flex: 1;
    }
    .input-group {
      margin-bottom: 20px;
    }
    .input-group input, .input-group textarea {
      width: 100%;
      padding: 14px 20px;
      border: 1.5px solid #e2e8f0;
      border-radius: 32px;
      font-family: inherit;
      transition: 0.2s;
    }
    .input-group input:focus, .input-group textarea:focus {
      outline: none;
      border-color: #8b5cf6;
      box-shadow: 0 0 0 3px rgba(79,70,229,0.2);
    }


    .project-img {
  width: 100%;
  height: 200px;
  object-fit: cover;
  border-radius: 10px 10px 0 0;
}

.project-card {
  overflow: hidden;
  border-radius: 10px;
  background: #fff;
}
    .contact-form button {
      background: #4f46e5;
      color: white;
      border: none;
      padding: 14px 30px;
      border-radius: 40px;
      font-weight: 600;
      cursor: pointer;
      width: 100%;
      font-size: 1rem;
    }
    footer {
      text-align: center;
      padding: 30px 0;
      border-top: 1px solid #e2e8f0;
      color: #64748b;
    }
    .name-highlight {
      display: inline-block;
      background: linear-gradient(120deg, #e0e7ff 0%, #c7d2fe 100%);
      padding: 0 8px;
      border-radius: 14px;
      cursor: pointer;
      transition: 0.2s;
    }
    .toast-msg {
      position: fixed;
      bottom: 25px;
      left: 50%;
      transform: translateX(-50%);
      background: #1e293b;
      color: white;
      padding: 12px 28px;
      border-radius: 50px;
      font-weight: 500;
      z-index: 200;
      opacity: 0;
      transition: 0.2s;
      pointer-events: none;
      backdrop-filter: blur(8px);
      white-space: nowrap;
    }
    @media (max-width: 850px) {
      .nav-links {
        display: none;
        flex-direction: column;
        width: 100%;
        background: white;
        padding: 20px;
        border-radius: 24px;
        margin-top: 12px;
      }
      .nav-links.show {
        display: flex;
      }
      .mobile-menu {
        display: block;
      }
      .hero-grid {
        flex-direction: column-reverse;
        text-align: center;
      }
      .hero-content h1 {
        font-size: 2.3rem;
      }
      .btn-group {
        justify-content: center;
      }
      .section-title:after {
        left: 50%;
        transform: translateX(-50%);
        width: 50%;
      }
      .section-title {
        text-align: center;
        display: block;
      }
      .contact-wrapper {
        flex-direction: column;
        padding: 28px;
      }
      .toast-msg {
        white-space: normal;
        text-align: center;
        width: 90%;
      }
    }
  </style>
</head>
<body>

<nav>
  <div class="container nav-inner">
    <div class="logo">📘 EduPort</div>
    <div class="mobile-menu" id="mobileMenuBtn">
      <i class="fas fa-bars"></i>
    </div>
    <ul class="nav-links" id="navLinks">
      <li><a href="#home">Home</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#education">Education</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </div>
</nav>

<main>
  <!-- Hero / Home Section -->
  <% if(hero_data && hero_data.length > 0) { %>
    <% hero_data.forEach(function(item){ %>
      <section id="home" class="hero">
        <div class="container hero-grid">
          <div class="hero-content slide-item" id="heroSlideLeft">
            <span class="hero-badge">
              <i class="fas fa-graduation-cap"></i> <%= item.position %>
            </span>
            <h1>
              <%= item.tagline %> <br>
              <span class="gradient-text"><%= item.subtitle %></span>
            </h1>
            <p>
              Hi, I'm 
              <strong class="name-highlight" id="dynamicNameTag">
                <%= item.fullname %>
              </strong>
              <%= item.details %>.
            </p>
            <div class="btn-group">
              <button class="btn-primary" id="exploreBtn">Explore Projects <i class="fas fa-arrow-right"></i></button>
              <button class="btn-outline" id="contactBtn">Contact Me</button>
            </div>
          </div>
          <div class="profile-img slide-item" id="heroSlideRight">
            <div class="img-wrapper">
              <img src="/<%= item.hero_image %>"
                   alt="Profile"
                   onerror="this.src='https://ui-avatars.com/api/?background=4f46e5&color=fff&bold=true&size=280&name=User'">
            </div>
          </div>
        </div>
      </section>
    <% }) %>
  <% } %>

  <!-- ===== NEW SIMPLE ABOUT SECTION - दुसरा डिझाइन ===== -->
 <section id="about" class="about-simple">
  <div class="container">
    <h2 class="section-title slide-up">
      <i class="fas fa-user"></i> About Me
    </h2>

    <% if (about_data.length > 0) { %>
      <% about_data.forEach(function(a){ %>

        <div class="about-card slide-up">
          <div class="about-flex">

            <!-- LEFT -->
            <div class="about-left">
              <h3><%= a.name %></h3>

              <p><%= a.description1 %></p>
              <p><%= a.description2 %></p>

              <div class="quote">
                <i class="fas fa-quote-left"></i>
                "<%= a.quote %>"
              </div>

              <p><%= a.hobby %></p>
            </div>

            <!-- RIGHT -->
            <div class="about-right">

              <div class="stat-simple">
                <div class="stat-num"><%= a.exp %></div>
                <div class="stat-label">Years Experience</div>
              </div>

              <div class="stat-simple">
                <div class="stat-num"><%= a.projects %></div>
                <div class="stat-label">Projects Completed</div>
              </div>

              <div class="stat-simple">
                <div class="stat-num"><%= a.students %></div>
                <div class="stat-label">Students Mentored</div>
              </div>

              <div class="stat-simple">
                <div class="stat-num"><%= a.countries %></div>
                <div class="stat-label">Countries Worked</div>
              </div>

            </div>

          </div>
        </div>

      <% }) %>
    <% } else { %>
      <p>No About Data Found</p>
    <% } %>

  </div>
</section>



<section id="stats">
  <div class="container">

    <h2 class="section-title slide-up">
      <i class="fas fa-trophy"></i> Achievements
    </h2>

    <div class="stats-grid">

      <div class="stat-box">
        <h3 class="counter" data-target="50">0</h3>
        <p>Projects Completed</p>
      </div>

      <div class="stat-box">
        <h3 class="counter" data-target="20">0</h3>
        <p>Happy Clients</p>
      </div>

      <div class="stat-box">
        <h3 class="counter" data-target="5">0</h3>
        <p>Years Experience</p>
      </div>

      <div class="stat-box">
        <h3 class="counter" data-target="100">0</h3>
        <p>Students Mentored</p>
      </div>

    </div>

  </div>
</section>
<section id="skills">
  <div class="container">
    
    <h2 class="section-title">
      <i class="fas fa-code"></i> Technical Skills
    </h2>

    <div class="skills-grid">

      <% if (skills_data && skills_data.length > 0) { %>

        <% skills_data.forEach(function(row){ %>

          <% let skillsArr = row.skills.split(","); %>

          <% skillsArr.forEach(function(skill){ %>

            <div class="skill-card">

              <!-- ICON -->
              <div class="skill-icon">
                <% if(skill.trim().toLowerCase() == "html"){ %>
                  <i class="fab fa-html5"></i>
                <% } else if(skill.trim().toLowerCase() == "css"){ %>
                  <i class="fab fa-css3-alt"></i>
                <% } else if(skill.trim().toLowerCase() == "javascript"){ %>
                  <i class="fab fa-js"></i>
                <% } else if(skill.trim().toLowerCase() == "nodejs"){ %>
                  <i class="fab fa-node-js"></i>
                <% } else if(skill.trim().toLowerCase() == "mysql"){ %>
                  <i class="fas fa-database"></i>
                <% } else { %>
                  <i class="fas fa-code"></i>
                <% } %>
              </div>

              <!-- TEXT -->
              <span><%= skill.trim() %></span>

            </div>

          <% }) %>

        <% }) %>

      <% } %>

    </div>
  </div>
</section>


  <!-- Education Section -->
 <section id="education">
  <div class="container">
    <h2 class="section-title slide-up">
      <i class="fas fa-university"></i> Academic Journey
    </h2>

    <div class="edu-grid">

      <% if (education_data.length > 0) { %>

        <% education_data.forEach(function(e){ %>

          <div class="edu-card slide-up">
            <div class="edu-icon">
              <i class="fas fa-graduation-cap"></i>
            </div>

            <h3><%= e.title %></h3>

            <span class="edu-date">
              <%= e.college %> | <%= e.year %>
            </span>

            <p><%= e.description %></p>
          </div>

        <% }) %>

      <% } %>

    </div>
  </div>
</section>
  
<!-- Projects Section -->
<section id="projects">
  <div class="container">
    <h2 class="section-title slide-up">
      <i class="fas fa-rocket"></i> Featured Projects
    </h2>

    <div class="projects-grid">

      <% if(projects && projects.length > 0){ %>

        <% projects.forEach(function(p){ %>
          <div class="project-card slide-up">

            <!-- IMAGE -->
            <% if(p.image){ %>
              <img src="/<%= p.image %>" alt="<%= p.title %>" class="project-img">
            <% } else { %>
              <img src="/default.jpg" alt="No Image" class="project-img">
            <% } %>

            <div class="project-content">
              <span class="project-tag"><%= p.tag %></span>
              <h3><%= p.title %></h3>
              <p><%= p.description %></p>

              <% if(p.link){ %>
                <a href="<%= p.link %>" target="_blank" class="project-link demo-link">
                  View →
                </a>
              <% } %>
            </div>

          </div>
        <% }) %>

      <% } else { %>

        <p style="text-align:center;">No Projects Found</p>

      <% } %>

    </div>
  </div>
</section>
  
 <section id="contact">
  <div class="container">
    <h2 class="section-title slide-up">
      <i class="fas fa-paper-plane"></i> Let's Connect
    </h2>

    <div class="contact-wrapper slide-up">

      <!-- LEFT SIDE -->
      <div class="contact-info">
        <h3>Get in touch</h3>

        <p style="margin-bottom: 30px;">
          I'm always open to discussing new projects or collaborations.
        </p>

        <% if(contact_data && contact_data.length > 0){ 
             var c = contact_data[0]; %>

          <div class="contact-detail">
            <i class="fas fa-user"></i>
            <span><%= c.name %></span>
          </div>

          <div class="contact-detail">
            <i class="fas fa-envelope"></i>
            <span><%= c.email %></span>
          </div>

          <div class="contact-detail">
            <i class="fas fa-map-marker-alt"></i>
            <span><%= c.address %></span>
          </div>

        <% } %>
      </div>

      <!-- RIGHT SIDE FORM -->
      <div class="contact-form">
        <form action="/save_contact_message" method="post">
          
          <div class="input-group">
            <input type="text" name="name" placeholder="Your name" required>
          </div>

          <div class="input-group">
            <input type="email" name="email" placeholder="Email address" required>
          </div>

          <div class="input-group">
            <!-- ✅ required add केला -->
            <textarea rows="4" name="message" placeholder="Write your message..." required></textarea>
          </div>

          <button type="submit">
            Send Message <i class="fas fa-arrow-right"></i>
          </button>

        </form>
      </div>

    </div>
  </div>
</section>
</main>

<footer>
  <div class="container">
    <p>© 2025 EduPortfolio — Designed with 💜 by Alex Rivera.</p>
  </div>
</footer>

<div id="toastMsg" class="toast-msg">✨ Action completed!</div>

<script>
  const slideElements = document.querySelectorAll('.slide-up');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  slideElements.forEach(el => observer.observe(el));

  const heroLeft = document.getElementById('heroSlideLeft');
  const heroRight = document.getElementById('heroSlideRight');
  if(heroLeft) {
    heroLeft.style.opacity = '0';
    heroLeft.style.transform = 'translateX(-40px)';
    heroRight.style.opacity = '0';
    heroRight.style.transform = 'translateX(40px)';
    setTimeout(() => {
      heroLeft.style.transition = 'all 0.7s ease-out';
      heroLeft.style.opacity = '1';
      heroLeft.style.transform = 'translateX(0)';
      heroRight.style.transition = 'all 0.7s ease-out';
      heroRight.style.opacity = '1';
      heroRight.style.transform = 'translateX(0)';
    }, 100);
  }


  const counters = document.querySelectorAll('.counter');

counters.forEach(counter => {
  counter.innerText = '0';

  const updateCounter = () => {
    const target = +counter.getAttribute('data-target');
    const c = +counter.innerText;

    const increment = target / 100;

    if (c < target) {
      counter.innerText = Math.ceil(c + increment);
      setTimeout(updateCounter, 20);
    } else {
      counter.innerText = target;
    }
  };

  updateCounter();
});
  const nameTag = document.getElementById('dynamicNameTag');
  const nameArray = ['vaishu Rivera', '✨ vaishu ✨', 'vaishu R.', ' (she/her)'];
  let nameIndex = 0;
  function slideNameChange() {
    nameIndex = (nameIndex + 1) % nameArray.length;
    nameTag.style.transition = 'all 0.2s ease';
    nameTag.style.transform = 'translateY(-6px)';
    nameTag.style.opacity = '0.5';
    setTimeout(() => {
      nameTag.textContent = nameArray[nameIndex];
      nameTag.style.transform = 'translateY(0px)';
      nameTag.style.opacity = '1';
    }, 150);
  }
  let nameInterval = setInterval(slideNameChange, 3800);
  if(nameTag) {
    nameTag.addEventListener('click', () => {
      clearInterval(nameInterval);
      slideNameChange();
      nameInterval = setInterval(slideNameChange, 3800);
      showToast('🎭 Name style animated!');
    });
  }

  const mobileBtn = document.getElementById('mobileMenuBtn');
  const navLinksMenu = document.getElementById('navLinks');
  mobileBtn.addEventListener('click', () => navLinksMenu.classList.toggle('show'));

  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const targetId = this.getAttribute('href');
      if(targetId === "#") return;
      const targetElement = document.querySelector(targetId);
      if(targetElement) {
        targetElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
        if(navLinksMenu.classList.contains('show')) navLinksMenu.classList.remove('show');
      }
    });
  });

  const exploreBtn = document.getElementById('exploreBtn');
  const contactBtnDirect = document.getElementById('contactBtn');
  if(exploreBtn) exploreBtn.addEventListener('click', () => document.getElementById('projects').scrollIntoView({ behavior: 'smooth' }));
  if(contactBtnDirect) contactBtnDirect.addEventListener('click', () => document.getElementById('contact').scrollIntoView({ behavior: 'smooth' }));

  function showToast(msg) {
    const toast = document.getElementById('toastMsg');
    toast.textContent = msg;
    toast.style.opacity = '1';
    setTimeout(() => toast.style.opacity = '0', 2200);
  }

  document.querySelectorAll('.demo-link').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const project = link.getAttribute('data-project');
      showToast(`🚀 Opening ${project} — interactive preview`);
    });
  });

  const contactForm = document.getElementById('contactForm');
  if(contactForm) {
    contactForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const message = document.getElementById('message').value.trim();
      if(!name || !email || !message) return showToast('⚠️ Please fill all fields.');
      if(!email.includes('@') || !email.includes('.')) return showToast('📧 Valid email required.');
      showToast(`✅ Thanks ${name}! I'll reply soon.`);
      contactForm.reset();
    });
  }

  document.querySelectorAll('.skill-badge').forEach(b => {
    b.addEventListener('click', () => showToast(`⚡ ${b.innerText.trim()} skill ready!`));
  });

  const footerPar = document.querySelector('footer p');
  if(footerPar) footerPar.innerHTML = footerPar.innerHTML.replace('2025', new Date().getFullYear());
  console.log("✅ New clean about section added!");
</script>
</body>
</html>